generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      String    @default("USER")
  phone     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  partner   Partner?
  partnerUser PartnerUser?

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  image       String?
  active      Boolean   @default(true)
  parentId    Int?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[] @relation("ProductCategories")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  description String
  price       Float
  comparePrice Float?
  sku         String?   @unique
  stock       Int       @default(0)
  image       String?
  images      String    @default("[]")
  specs       String    @default("{}")
  featured    Boolean   @default(false)
  active      Boolean   @default(true)
  categories  Category[] @relation("ProductCategories")
  orderItems  OrderItem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("products")
}

model Order {
  id              Int      @id @default(autoincrement())
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])
  partnerId       Int?
  status          String   @default("PENDING")
  paymentStatus   String?  @default("PENDING")
  paymentId       String?
  total           Float
  items           OrderItem[]
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String?
  notes           String?
  promoCodeId     Int?
  discountAmount  Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  commission      PartnerCommission?

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@map("order_items")
}

model Partner {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  user           User      @relation(fields: [userId], references: [id])
  percentage     Float     @default(5.0)
  referralCode   String    @unique
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  promoCodes     PromoCode[]
  commissions    PartnerCommission[]
  payments       PartnerPayment[]
  partnerUsers   PartnerUser[]

  @@map("partners")
}

model PromoCode {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  discountType    String    @default("percentage")
  discountValue   Float
  usageType       String    @default("single")
  maxActivations  Int       @default(1)
  activationCount Int       @default(0)
  startDate       DateTime?
  endDate         DateTime?
  minOrderAmount  Float?
  isFirstPurchase Boolean   @default(false)
  isActive        Boolean   @default(true)
  partnerId       Int?
  partner         Partner?  @relation(fields: [partnerId], references: [id])
  partnerUsers    PartnerUser[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("promo_codes")
}

model PartnerUser {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  partnerId   Int
  partner     Partner  @relation(fields: [partnerId], references: [id])
  referralSource String @default("link")
  promoCodeId Int?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id])
  boundAt     DateTime @default(now())

  @@map("partner_users")
}

model PartnerCommission {
  id          Int      @id @default(autoincrement())
  partnerId   Int
  partner     Partner  @relation(fields: [partnerId], references: [id])
  orderId     Int      @unique
  order       Order    @relation(fields: [orderId], references: [id])
  userId      Int
  amount      Float
  percentage  Float
  createdAt   DateTime @default(now())

  @@map("partner_commissions")
}

model PartnerPayment {
  id          Int      @id @default(autoincrement())
  partnerId   Int
  partner     Partner  @relation(fields: [partnerId], references: [id])
  amount      Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  paidAt      DateTime?

  @@map("partner_payments")
}